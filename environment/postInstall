#!/usr/bin/env bash
set -euo pipefail

: "${KOKKOS_SOURCE_DIR:=/opt/kokkos-src}"
: "${CUDA_HOME:=/usr/local/cuda}"
: "${NVCC_WRAPPER_DEFAULT_COMPILER:=/usr/bin/g++}"
: "${C_SPIKES_BUILD_PACKAGE:=1}"

if [[ -z "${C_SPIKES_CODE_DIR:-}" ]]; then
    if [[ -f /root/capsule/code/pyproject.toml ]]; then
        C_SPIKES_CODE_DIR=/root/capsule/code
    elif [[ -f /code/pyproject.toml ]]; then
        C_SPIKES_CODE_DIR=/code
    else
        C_SPIKES_CODE_DIR=/root/capsule/code
    fi
fi
export C_SPIKES_CODE_DIR

if [[ ! -f "${KOKKOS_SOURCE_DIR}/CMakeLists.txt" ]]; then
    echo "Missing Kokkos source at ${KOKKOS_SOURCE_DIR}; Dockerfile Kokkos prefetch did not complete." >&2
    exit 1
fi

python_nvidia_libs="$(python - <<'PY'
import glob
import site

print(":".join(sorted(glob.glob(site.getsitepackages()[0] + "/nvidia/*/lib"))))
PY
)"

export KOKKOS_SOURCE_DIR
export FETCHCONTENT_SOURCE_DIR_KOKKOS="${KOKKOS_SOURCE_DIR}"
export CUDA_HOME
export CUDACXX="${CUDA_HOME}/bin/nvcc"
export CXX="${KOKKOS_SOURCE_DIR}/bin/nvcc_wrapper"
export NVCC_WRAPPER_DEFAULT_COMPILER
export LD_LIBRARY_PATH="${python_nvidia_libs:+${python_nvidia_libs}:}${CUDA_HOME}/lib64${LD_LIBRARY_PATH:+:${LD_LIBRARY_PATH}}"
export CMAKE_BUILD_PARALLEL_LEVEL="${CMAKE_BUILD_PARALLEL_LEVEL:-4}"

cat >/etc/profile.d/c_spikes_build.sh <<EOF
export KOKKOS_SOURCE_DIR=${KOKKOS_SOURCE_DIR}
export FETCHCONTENT_SOURCE_DIR_KOKKOS=${KOKKOS_SOURCE_DIR}
export CUDA_HOME=${CUDA_HOME}
export CUDACXX=${CUDA_HOME}/bin/nvcc
export CXX=${KOKKOS_SOURCE_DIR}/bin/nvcc_wrapper
export NVCC_WRAPPER_DEFAULT_COMPILER=${NVCC_WRAPPER_DEFAULT_COMPILER}
export LD_LIBRARY_PATH=${python_nvidia_libs:+${python_nvidia_libs}:}${CUDA_HOME}/lib64\${LD_LIBRARY_PATH:+:\${LD_LIBRARY_PATH}}
export CMAKE_BUILD_PARALLEL_LEVEL=\${CMAKE_BUILD_PARALLEL_LEVEL:-4}
export OMP_NUM_THREADS=\${OMP_NUM_THREADS:-2}
export OMP_PROC_BIND=\${OMP_PROC_BIND:-spread}
export OMP_PLACES=\${OMP_PLACES:-threads}
export OPENBLAS_NUM_THREADS=\${OPENBLAS_NUM_THREADS:-2}
export MKL_NUM_THREADS=\${MKL_NUM_THREADS:-2}
export MPLBACKEND=\${MPLBACKEND:-Agg}
export QT_QPA_PLATFORM=\${QT_QPA_PLATFORM:-offscreen}
EOF

if [[ "${C_SPIKES_BUILD_PACKAGE}" == "1" ]]; then
    if [[ -f "${C_SPIKES_CODE_DIR}/pyproject.toml" ]]; then
        python -m pip install --no-deps --no-build-isolation -v "${C_SPIKES_CODE_DIR}"
    else
        echo "C-SPIKES source not found at ${C_SPIKES_CODE_DIR}; skipping package build during image construction."
    fi
fi
